# Database (SQLite — the production driver for this single-user local tool)
AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — Gemini only for this agent (auto-detected from the key below).
# AGENT_LLM_PROVIDER=gemini
# Model: the API serves the 3.1 Pro tier as 'gemini-3.1-pro-preview' for current keys.
AGENT_LLM_MODEL=gemini-3.1-pro-preview

# REQUIRED: your Gemini API key
AGENT_GEMINI_API_KEY=

# Agent execution tuning
# AGENT_MAX_RETRIES=2          # code regenerations on execution failure
# AGENT_EXEC_TIMEOUT_S=25      # sandbox wall-clock timeout per code run
# AGENT_SAMPLE_ROWS=5          # sample rows sent to the LLM (privacy boundary)

# Optional LangSmith tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=

PORT=8001
